function gclose() {
    local main_branch=master
    if git --no-pager branch | grep -q main; then
        main_branch=main
    fi
    local branch=$(git rev-parse --abbrev-ref HEAD)
    git checkout ${main_branch}
    git pull
    git branch --delete ${branch}
}

