function dnsgrep () {
    local dir=$HOME/repos/puppetroot/puppet/automod/meatpages/files/dnszones
    rg $1 --no-ignore --no-heading --no-line-number --no-filename $dir
}

function tfstatedel() {
    local bucket=$(grep 'bucket =' remotestate.tf | cut -d '"' -f2)
	local bucket_path=$(grep 'prefix =' remotestate.tf | cut -d '"' -f2)
    gsutil rm gs://${bucket}/${bucket_path}/default.tfstate
}

function pwgen() {
    openssl rand -base64 48 | tr -d '+/=' | head -c $1
}

function gcp() {
    project=$1
    area=$2
    open "https://console.cloud.google.com/$area?project=$project"
}

function newchart() {
    local name=$1
    mkdir -p ${name}/templates
    echo "apiVersion: v2" >> ${name}/Chart.yaml
    echo "name: ${name}" >> ${name}/Chart.yaml
    echo "description: A Helm chart for Kubernetes" >> ${name}/Chart.yaml
    echo "version: 0.1.0" >> ${name}/Chart.yaml
    touch ${name}/values.yaml
}

